# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# MAPBOX_ACCESS_TOKEN: Required for Mapbox visual map styles (Optional fallback to OpenStreetMap)
MAPBOX_ACCESS_TOKEN=YOUR_MAPBOX_TOKEN

# FIREBASE_DATABASE_URL: Base URL for your Firebase Realtime Database
FIREBASE_DATABASE_URL=https://your-project.firebaseio.com

# FIREBASE_API_KEY: Authentication/Database access API key if needed
FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
